# Trading Bot Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# PostgreSQL Database
# ============================================================
TRADING_DB_URL=postgresql://trader:trading123@localhost:5432/trading_journal

# For Docker deployment:
# TRADING_DB_URL=postgresql://trader:trading123@postgres:5432/trading_journal

# ============================================================
# Telegram Alerts (Optional)
# ============================================================
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================================
# Exchange API (Required for live trading)
# ============================================================
# BINANCE_API_KEY=your_api_key
# BINANCE_SECRET=your_api_secret

# For testnet (paper trading):
# BINANCE_API_KEY=testnet_key
# BINANCE_SECRET=testnet_secret

# ============================================================
# OpenAI API (Optional - for LLM-enhanced wiki validation)
# ============================================================
# OPENAI_API_KEY=sk-your_key_here

# ============================================================
# Frontend API URL (for Next.js build / static export)
# ============================================================
# NEXT_PUBLIC_API_URL=http://localhost:8090
# For production deployment:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ============================================================
# API Authentication (Required for production)
# ============================================================
# API_KEY=your_random_read_key_here
# ADMIN_KEY=your_random_admin_key_here
# NEXT_PUBLIC_API_KEY=your_random_read_key_here
# NEXT_PUBLIC_ADMIN_KEY=your_random_admin_key_here

# CORS_ORIGINS=http://localhost:3001,https://your-frontend-domain.com

# ============================================================
# Logging
# ============================================================
# LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG
