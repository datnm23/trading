# ============================================================
# Hybrid Trading System — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Trading Mode
TRADING_MODE=paper

# Exchange API (Binance / Bybit)
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_ID=binance
EXCHANGE_TESTNET=true

# FRED API (free, get at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Glassnode API (free tier limited, get at https://studio.glassnode.com/settings/api)
GLASSNODE_API_KEY=

# Telegram Bot for Alerts (get from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: OpenAI / Anthropic for Knowledge Engine
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Database
JOURNAL_DB_PATH=./data/journal.db

# Model Registry
MODEL_REGISTRY_PATH=./ml/models/registry.json
