# ============================================================
# Hybrid Trading System — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Trading Mode
TRADING_MODE=paper

# Service Mode (bot | api | export)
SERVICE_MODE=bot

# DNSE LightSpeed OpenAPI v2 (chứng khoán VN)
# Lấy API Key + Secret tại EntradeX. Dùng cho endpoint cần xác thực (account,
# market data real-time). LỊCH SỬ OHLCV qua chart-api công khai KHÔNG cần key.
DNSE_API_KEY=
DNSE_API_SECRET=

# Telegram Bot for Alerts (get from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: OpenAI / Anthropic for Knowledge Engine
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Database (PostgreSQL trong Docker network)
TRADING_DB_URL=postgresql://trader:trading123@postgres:5432/trading_journal

# Model Registry
MODEL_REGISTRY_PATH=./ml/models/registry.json

# Grafana admin password
GF_SECURITY_ADMIN_PASSWORD=changeme
